+++ b/backend/app/gateway/__init__.py
@@ -1,4 +1,20 @@
-from .app import app, create_app
-from .config import GatewayConfig, get_gateway_config
-
+# Lazy imports: importing app.gateway (or any submodule like app.gateway.config)
+# must NOT trigger the full app instantiation chain, because that chain calls
+# get_app_config() → resolves ${DEERFLOW_HOST_PATH} → needs .env already loaded.
+# Uvicorn always imports app.gateway.app:app directly, so this __init__ only
+# needs to provide convenience re-exports for explicit callers.
 __all__ = ["app", "create_app", "GatewayConfig", "get_gateway_config"]
+
+
+def __getattr__(name: str):
+    if name in ("app", "create_app"):
+        from .app import app, create_app as _create_app  # noqa: PLC0415
+        globals()["app"] = app
+        globals()["create_app"] = _create_app
+        return globals()[name]
+    if name in ("GatewayConfig", "get_gateway_config"):
+        from .config import GatewayConfig, get_gateway_config  # noqa: PLC0415
+        globals()["GatewayConfig"] = GatewayConfig
+        globals()["get_gateway_config"] = get_gateway_config
+        return globals()[name]
