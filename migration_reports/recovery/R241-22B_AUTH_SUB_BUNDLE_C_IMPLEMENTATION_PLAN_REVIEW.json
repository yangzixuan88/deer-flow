  "user_context_implementation_contract": {
    "module": "backend/app/gateway/deerflow/runtime/user_context.py",
    "lines": 147,
    "upstream_content_verified": true,

    "core_type_definitions": [
      {
        "name": "CurrentUser",
        "type": "Protocol (structural)",
        "requirement": ".id: str attribute",
        "note": "Any object with .id: str satisfies this protocol"
      },
      {
        "name": "_current_user",
        "type": "ContextVar[CurrentUser | None]",
        "default": "None",
        "key": "'deerflow_current_user'"
      }
    ],

    "api_surface": [
      {
        "fn": "set_current_user(user: CurrentUser) -> Token[CurrentUser | None]",
        "contract": "Returns reset token; caller MUST call reset_current_user(token) in finally"
      },
      {
        "fn": "reset_current_user(token: Token[CurrentUser | None]) -> None",
        "contract": "Restores context to state captured by token"
      },
      {
        "fn": "get_current_user() -> CurrentUser | None",
        "contract": "Safe to call in any context; returns None if unset"
      },
      {
        "fn": "require_current_user() -> CurrentUser",
        "contract": "Raises RuntimeError if unset (NOT Optional)"
      },
      {
        "fn": "get_effective_user_id() -> str",
        "contract": "Returns user.id or 'default' if unset"
      },
      {
        "fn": "resolve_user_id(value: str | None | _AutoSentinel, method_name: str) -> str | None",
        "contract": "AUTO → contextvar; str → verbatim; None → bypass isolation"
      }
    ],

    "three_state_semantics": {
      "AUTO": "Read from contextvar; raise RuntimeError if unset",
      "explicit_str": "Use provided str verbatim, overriding contextvar",
      "explicit_None": "No WHERE clause — migration/CLI bypass"
    },

    "sentinel_pattern": {
      "class": "_AutoSentinel",
      "singleton": "AUTO",
      "repr": "<AUTO>",
      "used_by": "resolve_user_id() for repository user_id parameter"
    },

    "implementation_constraints": [
      "ContextVar is asyncio task-local — naturally isolated per-request",
      "asyncio.create_task() inherits parent context (intentional)",
      "Use contextvars.copy_context() for background tasks that need isolation",
      "Token-based reset ensures context is restored even on exception"
    ]
  },

  "contextvar_token_reset_contract": {
    "pattern_name": "Token-based ContextVar Reset Pattern",
    "mandatory": true,
    "pattern": [
      "token = set_current_user(user)",
      "try:",
      "    # code that uses user context",
      "finally:",
      "    reset_current_user(token)"
    ],
    "why_mandatory": "Without reset, ContextVar retains reference to user object; token ensures cleanup even on exception",
    "anti_pattern": [
      "DO NOT: set_current_user(user) without reset",
      "DO NOT: catch and swallow exception before reset",
      "DO NOT: use asyncio.create_task without copy_context when isolation needed"
    ],
    "test_contract": {
      "CV-ISO-01": "set → get → reset → get=None (sequential)",
      "CV-ISO-02": "Task1 sees A, Task2 sees B (concurrent)",
      "CV-ISO-03": "Child sees parent context (inheritance)",
      "CV-ISO-04": "Child with copy_context sees None (isolation)",
      "CV-ISO-05": "Token reset restores previous state"
    }
  },

