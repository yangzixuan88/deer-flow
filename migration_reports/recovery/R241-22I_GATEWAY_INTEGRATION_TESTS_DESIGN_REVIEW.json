  "10_danger_zones": {
    "AUTH_MIDDLEWARE_ENABLED_false": {
      "severity": "HIGH",
      "description": "Disabling AuthMiddleware alone creates fail-open gateway — all protected routes return 404 instead of 401, masking auth absence",
      "manifests_as": "User sees 404 on /me and /change-password instead of being prompted to login",
      "correct_rollback": "Disable both AUTH_MIDDLEWARE_ENABLED AND AUTH_ROUTES_ENABLED together"
    },
    "memory_backend_feedback": {
      "severity": "MEDIUM",
      "description": "feedback_repo is None when DATABASE_BACKEND=memory — feedback operations will raise AttributeError",
      "manifests_as": "AttributeError on app.state.feedback_repo when feedback router calls get_feedback_repo()",
      "workaround": "get_feedback_repo() should return a no-op feedback repo or handle None gracefully"
    },
    "jsonl_multiprocess_collision": {
      "severity": "LOW",
      "description": "JsonlRunEventStore _seq_counters is in-process only — multiple workers writing same thread will have independent counters",
      "manifests_as": "Duplicate seq values in run_events when multiple uvicorn workers serve same thread",
      "acceptable_for": "Single-worker dev/test environments only"
    }
  },

