# OpenClaw System Environment Variables
# ============================================
# Development/Production Environment Configuration
# ============================================

# Platform Detection
LOCAL_IP=127.0.0.1
OS_PLATFORM=Windows

# ============================================
# PRODUCTION: Security Credentials
# ============================================

# Redis Password (REQUIRED for production)
REDIS_PASSWORD=change_me_in_production

# Grafana Admin Password
GRAFANA_PASSWORD=change_me_in_production

# n8n API Key
N8N_API_KEY=change_me_in_production

# n8n Encryption Key
N8N_ENCRYPTION_KEY=super-secret-claw-key-change-me

# ============================================
# Cloudflare Tunnel Configuration
# ============================================
# Create a tunnel on https://dash.cloudflare.com/ -> Zero Trust -> Access -> Tunnels
# Copy the TOKEN and paste it here.
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ============================================
# Application Ports
# ============================================
FEISHU_WEBHOOK_PORT=8080
FEISHU_WEBHOOK_HOST=openclaw-app

# Health & Metrics Server
HEALTH_PORT=8081

# ============================================
# n8n Workflow Platform
# ============================================
N8N_HOST=n8n
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/

# ============================================
# Dify AI Workflow Platform
# ============================================
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=change_me_in_production
DIFY_TIMEOUT_MS=60000

# ============================================
# Unified Workflow Engine Config
# ============================================
# Bridge type: MEMORY | HTTP_POLL | WEBHOOK_TRIGGER | SHARED_STORAGE | STREAMING_BUFFER
BRIDGE_TYPE=MEMORY
# Redis for shared storage bridge (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
# Max parallel nodes in unified executor
MAX_PARALLEL_NODES=5
# Circuit breaker threshold
CIRCUIT_BREAKER_THRESHOLD=3

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30

# ============================================
# Feature Flags
# ============================================
NODE_ENV=production
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true
