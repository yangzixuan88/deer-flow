{
  "mcpServers": {
    "tavily": {
      "enabled": true,
      "type": "sse",
      "command": null,
      "args": [],
      "env": {
        "TAVILY_API_KEY": "$TAVILY_API_KEY"
      },
      "url": "https://mcp.tavily.com/mcp",
      "headers": {},
      "oauth": null,
      "description": "Tavily search (enabled R147I; isolated probe; key via env)"
    },
    "exa": {
      "enabled": false,
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "exa-mcp"
      ],
      "env": {
        "EXA_API_KEY": "$EXA_API_KEY"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Exa AI 高级内容检索 (disabled R147A: EXA_API_KEY missing from environment; re-enable after credentials provided)"
    },
    "lark": {
      "enabled": false,
      "type": "stdio",
      "command": "pnpm.cmd",
      "args": [
        "dlx",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "$LARK_APP_ID",
        "-s",
        "$LARK_APP_SECRET",
        "--token-mode",
        "tenant_access_token"
      ],
      "env": {
        "LARK_TOKEN_MODE": "tenant_access_token",
        "NO_PROXY": "open.feishu.cn"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Lark/Feishu MCP (paused R147I: SDK token attach bug; re-enable after SDK patch)"
    },
    "pinecone": {
      "enabled": false,
      "type": "stdio",
      "command": "npx.cmd",
